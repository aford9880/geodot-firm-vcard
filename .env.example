# --- Telegram Bot API: куда летят заявки с формы ---
# 1) Создайте бота через @BotFather -> получите токен.
# 2) Узнайте chat_id (например, через @userinfobot) или ID группы, куда добавлен бот.
# Без значений форма работает в демо-режиме (имитация успешной отправки).
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# --- Email-уведомления (mock) ---
# В проде можно подключить сервис вроде Formspree/Web3Forms (endpoint).
# Без значения отправка имитируется (console.log).
VITE_EMAIL_ENDPOINT=